# Local dev default (SQLite, zero config)
DATABASE_URL="file:./dev.db"

# For production on Vercel, switch prisma/schema.prisma datasource to "postgresql"
# and set DATABASE_URL to a Neon/Supabase/Vercel Postgres connection string, e.g.:
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Optional: enables higher-quality theme clustering, urgency scoring and
# translation via Groq (primary) or OpenAI (secondary). The app works fully
# without either key using a built-in rule-based multilingual NLP fallback.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
OPENAI_API_KEY=
