# Supabase Postgres (via Vercel integration). Run `vercel env pull .env`
# after linking this project to populate these automatically, or copy them
# from Vercel → Storage → your Supabase database → ".env.local" tab.
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Optional: enables higher-quality theme clustering, urgency scoring and
# translation via Groq (primary) or OpenAI (secondary). The app works fully
# without either key using a built-in rule-based multilingual NLP fallback.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
OPENAI_API_KEY=
